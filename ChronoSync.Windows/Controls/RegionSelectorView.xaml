<UserControl x:Class="ChronoSync.Windows.Controls.RegionSelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="320" d:DesignWidth="480">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Video frame with mouse-drawable region overlay -->
        <Border Grid.Row="0" Background="#1A1A1A" CornerRadius="4" ClipToBounds="True">
            <Grid x:Name="FrameHost">
                <Image x:Name="FrameImage" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Source="{Binding CurrentFrame, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                <Canvas x:Name="OverlayCanvas" Background="Transparent"
                        Cursor="Cross"
                        MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
                        MouseMove="Overlay_MouseMove"
                        MouseLeftButtonUp="Overlay_MouseLeftButtonUp"/>
                <Rectangle x:Name="SelectedRect"
                           Stroke="#FF3B30" StrokeThickness="2"
                           Fill="#33FF3B30"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"/>
                <Rectangle x:Name="AutoRect"
                           Stroke="#FF9500" StrokeThickness="2"
                           StrokeDashArray="4,2"
                           Fill="#22FF9500"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Seek slider -->
        <DockPanel Grid.Row="1" Margin="0,8,0,0" LastChildFill="True">
            <TextBlock DockPanel.Dock="Left" Text="时间:" VerticalAlignment="Center"
                       Margin="0,0,8,0" FontSize="12" Foreground="#666"/>
            <TextBlock x:Name="TimeText" DockPanel.Dock="Right" VerticalAlignment="Center"
                       Margin="8,0,0,0" FontWeight="SemiBold" MinWidth="60" TextAlignment="Right"/>
            <Slider x:Name="SeekSlider" Minimum="0" Maximum="100" Value="0"
                    VerticalAlignment="Center" Margin="4,0"
                    Thumb.DragCompleted="SeekSlider_DragCompleted"
                    PreviewMouseLeftButtonUp="SeekSlider_PreviewMouseLeftButtonUp"/>
        </DockPanel>

        <!-- Random button + region info -->
        <DockPanel Grid.Row="2" Margin="0,4,0,0">
            <Button DockPanel.Dock="Right" Content="随机跳转" Click="RandomBtn_Click"
                    Padding="10,4" FontSize="12" Background="#FF9500" Foreground="White" BorderThickness="0"/>
            <TextBlock x:Name="RegionInfoText" VerticalAlignment="Center" Foreground="#666" FontSize="12"
                       Text="未选择区域"/>
        </DockPanel>
    </Grid>
</UserControl>